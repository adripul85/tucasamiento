{
  "entities": {
    "Wedding": {
      "title": "Wedding",
      "description": "Core wedding details and ownership.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the wedding owner." },
        "partner1": { "type": "string", "description": "Name of the first partner." },
        "partner2": { "type": "string", "description": "Name of the second partner." },
        "date": { "type": "string", "format": "date", "description": "Wedding date." },
        "location": { "type": "string", "description": "Wedding location." },
        "budget": { "type": "number", "description": "Total wedding budget." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "partner1", "partner2"]
    },
    "Guest": {
      "title": "Guest",
      "description": "A guest invited to the wedding.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "name": { "type": "string", "description": "Guest name." },
        "email": { "type": "string", "format": "email", "description": "Guest email." },
        "status": { "type": "string", "enum": ["invited", "confirmed", "declined"], "description": "RSVP status." },
        "plusOne": { "type": "boolean", "description": "Whether the guest has a plus one." },
        "plusOneName": { "type": "string", "description": "Name of the guest's plus one." },
        "dietaryRestrictions": { "type": "string", "description": "Guest dietary restrictions." },
        "color": { "type": "string", "description": "Color assigned to the guest for the seating chart." }
      },
      "required": ["weddingId", "name", "status"]
    },
    "Task": {
      "title": "Task",
      "description": "A planning task for the wedding.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "title": { "type": "string", "description": "Task title." },
        "description": { "type": "string", "description": "Task details." },
        "category": { "type": "string", "description": "Task category." },
        "timeframe": { "type": "string", "description": "Task timeframe (e.g., 'De 10 a 12 meses')." },
        "dueDate": { "type": "string", "format": "date", "description": "Task deadline." },
        "completed": { "type": "boolean", "description": "Completion status." },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "Task priority." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["weddingId", "title", "completed"]
    },
    "BudgetItem": {
      "title": "BudgetItem",
      "description": "An expense item in the wedding budget.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "category": { "type": "string", "description": "Expense category." },
        "name": { "type": "string", "description": "Item name." },
        "estimated": { "type": "number", "description": "Estimated cost." },
        "paid": { "type": "number", "description": "Amount already paid." }
      },
      "required": ["weddingId", "category", "name", "estimated", "paid"]
    },
    "FavoriteVendor": {
      "title": "FavoriteVendor",
      "description": "A vendor saved by the user.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "vendorId": { "type": "string", "description": "External vendor ID." },
        "name": { "type": "string", "description": "Vendor name." },
        "category": { "type": "string", "description": "Vendor category." },
        "address": { "type": "string", "description": "Vendor address." },
        "rating": { "type": "number", "description": "Vendor rating." },
        "photo": { "type": "string", "format": "uri", "description": "Vendor photo URL." },
        "phone": { "type": "string", "description": "Vendor phone number." },
        "website": { "type": "string", "format": "uri", "description": "Vendor website URL." }
      },
      "required": ["weddingId", "vendorId", "name"]
    },
    "Payment": {
      "title": "Payment",
      "description": "An individual payment for a budget item.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "budgetItemId": { "type": "string", "description": "Reference to the budget item." },
        "itemName": { "type": "string", "description": "Name of the item at the time of payment." },
        "amount": { "type": "number", "description": "Amount paid." },
        "date": { "type": "string", "format": "date-time", "description": "Payment date." },
        "method": { "type": "string", "description": "Payment method (e.g., Cash, Credit Card)." }
      },
      "required": ["weddingId", "budgetItemId", "itemName", "amount", "date"]
    },
    "Post": {
      "title": "Post",
      "description": "A community post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Author UID." },
        "authorName": { "type": "string", "description": "Author display name." },
        "authorPhoto": { "type": "string", "format": "uri", "description": "Author photo URL." },
        "content": { "type": "string", "description": "Post content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "authorName", "content", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "User email." },
        "displayName": { "type": "string", "description": "User display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role." }
      },
      "required": ["email", "role"]
    },
    "WeddingWebsite": {
      "title": "WeddingWebsite",
      "description": "Public wedding website configuration.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "templateId": { "type": "string", "description": "Selected template ID." },
        "welcomeTitle": { "type": "string", "description": "Welcome title." },
        "welcomeMessage": { "type": "string", "description": "Welcome message." },
        "invitationText": { "type": "string", "description": "Invitation text." },
        "published": { "type": "boolean", "description": "Whether the website is public." },
        "theme": { "type": "object", "description": "Theme settings." }
      },
      "required": ["weddingId", "templateId", "published"]
    },
    "Regalo": {
      "title": "Regalo",
      "description": "A gift item in the honeymoon list.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "title": { "type": "string", "description": "Gift title." },
        "description": { "type": "string", "description": "Gift details." },
        "targetAmount": { "type": "number", "description": "Total amount needed." },
        "collectedAmount": { "type": "number", "description": "Amount already collected." },
        "imageUrl": { "type": "string", "format": "uri", "description": "Gift image URL." },
        "category": { "type": "string", "enum": ["flight", "hotel", "experience", "other"], "description": "Gift category." },
        "completed": { "type": "boolean", "description": "Whether the goal is reached." },
        "order": { "type": "number", "description": "Display order." }
      },
      "required": ["weddingId", "title", "targetAmount", "collectedAmount", "category", "completed", "order"]
    },
    "Contribucion": {
      "title": "Contribucion",
      "description": "A contribution from a guest to a gift.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "giftId": { "type": "string", "description": "Reference to the gift." },
        "guestName": { "type": "string", "description": "Name of the contributor." },
        "amount": { "type": "number", "description": "Amount contributed." },
        "message": { "type": "string", "description": "Message from the guest." },
        "date": { "type": "string", "format": "date-time", "description": "Contribution date." },
        "paymentId": { "type": "string", "description": "Mercado Pago payment reference." }
      },
      "required": ["weddingId", "giftId", "guestName", "amount", "date"]
    },
    "Table": {
      "title": "Table",
      "description": "A table in the seating chart.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Table name or number." },
        "x": { "type": "number", "description": "X coordinate on the canvas." },
        "y": { "type": "number", "description": "Y coordinate on the canvas." },
        "type": { "type": "string", "enum": ["round", "rectangular"], "description": "Table shape." },
        "capacity": { "type": "number", "description": "Seating capacity." },
        "guestIds": { "type": "array", "items": { "type": "string" }, "description": "IDs of guests assigned to this table." }
      },
      "required": ["name", "x", "y", "type", "capacity", "guestIds"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between a couple and a vendor.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "vendorId": { "type": "string", "description": "Reference to the vendor." },
        "coupleName": { "type": "string", "description": "Name of the couple." },
        "vendorName": { "type": "string", "description": "Name of the vendor." },
        "lastMessage": { "type": "string", "description": "The content of the last message." },
        "lastMessageAt": { "type": "string", "format": "date-time", "description": "Timestamp of the last message." },
        "coupleId": { "type": "string", "description": "User ID of the couple." },
        "vendorUserId": { "type": "string", "description": "User ID of the vendor." }
      },
      "required": ["weddingId", "vendorId", "coupleName", "vendorName", "coupleId", "vendorUserId"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string", "description": "Reference to the chat." },
        "senderId": { "type": "string", "description": "User ID of the sender." },
        "text": { "type": "string", "description": "Message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "TimelineEvent": {
      "title": "TimelineEvent",
      "description": "A minute-by-minute event for the wedding day.",
      "type": "object",
      "properties": {
        "weddingId": { "type": "string", "description": "Reference to the wedding." },
        "time": { "type": "string", "description": "Time of the event (HH:mm)." },
        "title": { "type": "string", "description": "Event title." },
        "description": { "type": "string", "description": "Event details." },
        "location": { "type": "string", "description": "Event location." },
        "notify": { "type": "boolean", "description": "Whether to send a notification." },
        "notified": { "type": "boolean", "description": "Whether the notification has been sent." }
      },
      "required": ["weddingId", "time", "title", "notify"]
    }
  },
  "firestore": {
    "/weddings/{weddingId}": {
      "schema": "Wedding",
      "description": "Wedding details."
    },
    "/weddingWebsites/{weddingId}": {
      "schema": "WeddingWebsite",
      "description": "Public wedding website configuration."
    },
    "/weddings/{weddingId}/guests/{guestId}": {
      "schema": "Guest",
      "description": "Guest list for a wedding."
    },
    "/weddings/{weddingId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Planning tasks for a wedding."
    },
    "/weddings/{weddingId}/budgetItems/{budgetItemId}": {
      "schema": "BudgetItem",
      "description": "Budget items for a wedding."
    },
    "/weddings/{weddingId}/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Individual payments for a wedding."
    },
    "/weddings/{weddingId}/favoriteVendors/{favoriteVendorId}": {
      "schema": "FavoriteVendor",
      "description": "Favorite vendors for a wedding."
    },
    "/weddings/{weddingId}/regalos/{giftId}": {
      "schema": "Regalo",
      "description": "Honeymoon gift list."
    },
    "/weddings/{weddingId}/contribuciones/{contributionId}": {
      "schema": "Contribucion",
      "description": "Contributions to honeymoon gifts."
    },
    "/weddings/{weddingId}/tables/{tableId}": {
      "schema": "Table",
      "description": "Tables in the seating chart."
    },
    "/weddings/{weddingId}/timeline/{eventId}": {
      "schema": "TimelineEvent",
      "description": "The wedding day schedule."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations between couples and vendors."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    }
  }
}
